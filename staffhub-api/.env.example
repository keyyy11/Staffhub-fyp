PORT=3000
MONGODB_URI=mongodb://localhost:27017/staffhub

# MongoDB Atlas — for npm run migrate:atlas (local → cloud). Do not commit real password.
# MONGODB_URI_ATLAS=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/staffhub?retryWrites=true&w=majority
# MONGODB_URI_SOURCE=mongodb://localhost:27017/staffhub

# Vercel API deploy — set in Vercel project Environment Variables (Hobby / free):
# MONGODB_URI=<same Atlas URI as MONGODB_URI_ATLAS>
# JWT_SECRET=<same as local — required for migrated users>
# CORS_ORIGIN=https://your-cms.vercel.app

JWT_SECRET=ubah-ini-kepada-string-rahsia-anda

# Production CORS — comma-separated allowed origins (CMS + mobile web)
# CORS_ORIGIN=https://staffhub-cms.vercel.app,https://your-app.vercel.app

# Workplace: 16, Jalan Puncak Bayu 10, 81300 Johor Bahru, Johor (from Google Maps)
WORKPLACE_LAT=1.5434665
WORKPLACE_LNG=103.6123308
WORKPLACE_RADIUS_METERS=60
EXPECTED_CLOCK_IN_HOUR=9
EXPECTED_CLOCK_IN_MINUTE=0
ADMIN_SECRET=admin123

# Email (forgot password) — Gmail example:
# 1. Enable 2FA on Google account
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-char password as SMTP_PASS (not your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
APP_NAME=Staff Hub
RESET_CODE_EXPIRY_MINUTES=15
# Dev only: log reset code to API console when email is sent
LOG_RESET_CODE=true

# Cuti umum (JSON array). Kosongkan untuk guna senarai lalai dalam kod (cuti persekutuan MY).
# Contoh: [{"date":"2026-01-01","name":"Tahun Baru","hourlyPayMultiplier":2}]
# PUBLIC_HOLIDAYS_JSON=
# Pengganda sejam jika bekerja pada hari cuti umum (paparan + API)
PUBLIC_HOLIDAY_HOURLY_MULTIPLIER=2

# Supervisor: promote existing staff via Admin API only, unless you enable legacy self-registration:
# ALLOW_SUPERVISOR_SELF_REGISTER=true
# SUPERVISOR_SECRET=supervisor123
